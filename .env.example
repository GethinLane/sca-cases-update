# ──────────────────────────────────────────────────────────────
# Airtable
# ──────────────────────────────────────────────────────────────

# Read-only token covering the Cases, Feedback, and "Users ai" bases.
# Scopes: data.records:read, schema.bases:read
AIRTABLE_TOKEN=pat...

# Base IDs (start with "app...")
AIRTABLE_CASES_BASE_ID=app...
AIRTABLE_FEEDBACK_BASE_ID=app...
AIRTABLE_TRANSCRIPTS_BASE_ID=app...   # "Users ai" base — only needed for Transcript Insights

# Write-scoped token for the Feedback base — used by the Transcript Insights
# "Save selected" action to write to "Missing Case Details".
# Scopes: data.records:write on Feedback base only.
AIRTABLE_FEEDBACK_WRITE_TOKEN=pat...

# Write-scoped token for the Cases base — used by the new two-stage feedback
# flow (POST /api/apply-edit) when the user clicks "Update Airtable" on a
# rewrite suggestion. Keep this separate from the feedback write token: this
# token only needs data.records:write on the Cases base.
# Create at https://airtable.com/create/tokens
AIRTABLE_CASES_WRITE_TOKEN=pat...

# ──────────────────────────────────────────────────────────────
# AI providers
# ──────────────────────────────────────────────────────────────

# Anthropic — used by /api/feedback-triage (Sonnet 4.6), /api/draft-rewrites
# (Opus 4.7), /api/full-analysis, and /api/triage-case.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — used by /api/transcripts/analyse (gpt-5.4) and the legacy
# /api/analyse-case route.
OPENAI_API_KEY=sk-...

# Optional overrides
# TRIAGE_AI_PROVIDER=anthropic            # default
# TRIAGE_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# FEEDBACK_TRIAGE_MAX_SEARCHES=6
# DRAFT_REWRITES_MAX_SEARCHES=8
# DRAFT_REWRITES_MAX_TOKENS=16000
# FULL_ANALYSIS_MODEL=claude-sonnet-4-6
# FULL_ANALYSIS_MAX_SEARCHES=12
# OPENAI_REASONING_EFFORT=medium
# TRANSCRIPTS_OPENAI_MODEL=gpt-5.4
# OPENAI_TRANSCRIPTS_EFFORT=medium

# ──────────────────────────────────────────────────────────────
# Vercel Blob (used by the guideline audit cache and the new
# feedback-analysis cache)
# ──────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ──────────────────────────────────────────────────────────────
# Auth — Google OAuth via Auth.js (NextAuth v5)
# ──────────────────────────────────────────────────────────────

# Secret used to sign session JWTs. Generate one with:
#   openssl rand -base64 32
# or:
#   npx auth secret
# MUST be set in every environment (local + production). Rotating
# this invalidates all existing sessions.
AUTH_SECRET=

# Google OAuth credentials — create at
# https://console.cloud.google.com/apis/credentials
#   → "Create credentials" → "OAuth client ID" → "Web application"
# Authorised redirect URIs:
#   http://localhost:3000/api/auth/callback/google     (dev)
#   https://<your-vercel-domain>/api/auth/callback/google   (prod)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated allowlist of Google account emails permitted to sign in.
# Anyone signing in with a Google account NOT in this list is rejected,
# even if they successfully authenticate with Google. Case-insensitive.
# Example: ALLOWED_EMAILS=alice@example.com,bob@example.com
ALLOWED_EMAILS=
